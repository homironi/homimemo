---
import { rakutenWidgetHtml } from "@/data/affiliateLinks";
import { getEntry } from "astro:content";

export type Props = { type: "rakutenWidget" } | { type: "productLink"; id: string };

const props = Astro.props;

const isProduction = import.meta.env.PROD;

const affiliateHtml = props.type === "rakutenWidget" ? rakutenWidgetHtml : (await getEntry("affiliates", props.id))?.body;
if(!affiliateHtml){
  throw new Error(`Not found affiliate html.${props.type === "productLink" && ` id: ${props.id}`}`);
}
---

<div class="container">
  {isProduction 
  ? <Fragment set:html={affiliateHtml} /> 
  : <p>{props.type}{props.type === "productLink" && `, id:${props.id} title:${(await getEntry("affiliates", props.id))?.data.title}`}</p> }
</div>

<style>
  .container {
    margin: 0 auto;
    padding: 8px;
    max-width: 100%;
    background-color: var(--color-main);
    border: solid 1px var(--border-color-main);
  }
  
  .container::before{
    content: "広告";
    color: var(--text-color-pale);
    display: block;
    font-size: 0.75rem;
    padding-bottom: 4px;
  }

  /* 生成されるかんたんリンクの文字色を強制的に上書きするため、以降importantを使用 */
  :global(.easyLink-info-btn-amazon) {
    color: var(--text-color-black) !important;
  }

  :global(div.easyLink-box) {
    background-color: var(--color-main) !important;
    color: var(--text-color) !important;
    border-color: var(--border-color-main) !important;
  }

  :global(div.easyLink-box div.easyLink-info p.easyLink-info-name a) {
    color: var(--text-color) !important;
  }
</style>
