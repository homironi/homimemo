{
  "name": "homimemo",
  "type": "module",
  "version": "3.0.0",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && pnpm run build:redirects && astro build",
    "build:redirects": "tsx scripts/generateRedirects.ts",
    "preview": "pnpm build && wrangler dev",
    "astro": "astro",
    "style-lint": "stylelint \"**/*.css\" --ignore-path .gitignore",
    "lint": "eslint . || pnpm run style-lint",
    "lint-fix": "eslint --fix .",
    "new-article": "tsx scripts/createNewArticle.ts",
    "update-article": "tsx scripts/updateArticle.ts",
    "svg": "svgo --folder ./src/assets/icons --recursive "
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.4.6",
    "astro-expressive-code": "^0.43.1",
    "astro-icon": "^1.1.5",
    "schema-dts": "^2.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@inquirer/prompts": "^8.5.2",
    "@playform/compress": "^0.2.3",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/hast": "^3.0.4",
    "@typescript-eslint/parser": "^8.61.0",
    "astro-eslint-parser": "^1.4.0",
    "eslint": "^10.4.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "gray-matter": "^4.0.3",
    "jiti": "^2.7.0",
    "nanoid": "^5.1.11",
    "npm-run-all": "^4.1.5",
    "rehype-github-color": "^1.0.0",
    "rehype-slug": "^6.0.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "svgo": "^4.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "unist-util-visit": "^5.1.0",
    "wrangler": "^4.98.0",
    "zod": "^4.4.3"
  }
}